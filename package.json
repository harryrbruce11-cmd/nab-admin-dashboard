{
  "name": "nab-admin-dashboard",
  "productName": "NAB Admin Dashboard",
  "version": "0.1.5",
  "private": true,
  "description": "NAB Admin Dashboard desktop app",
  "author": "Harry Bruce",
  "main": "electron/main.js",
  "homepage": "./",
  "scripts": {
    "dev": "concurrently \"npm run react-dev\" \"npm run electron-dev\"",
    "react-dev": "vite --host 0.0.0.0",
    "electron-dev": "wait-on http://localhost:5173 && ELECTRON_START_URL=http://localhost:5173 electron .",
    "build": "vite build",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "release": "npm run dist && firebase deploy --only hosting",
    "release:win": "npm run dist:win && firebase deploy --only hosting",
    "release:mac": "npm run dist:mac && firebase deploy --only hosting"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "electron-updater": "^6.8.3",
    "firebase": "^12.13.0",
    "react": "latest",
    "react-dom": "latest",
    "react-router-dom": "latest"
  },
  "devDependencies": {
    "concurrently": "latest",
    "electron": "latest",
    "electron-builder": "latest",
    "vite": "latest",
    "wait-on": "latest"
  },
  "build": {
    "appId": "com.nab.admin.dashboard",
    "productName": "NAB Admin Dashboard",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
   "publish": [
  {
    "provider": "generic",
    "url": "https://nabadminapp.web.app/"
  }
],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
